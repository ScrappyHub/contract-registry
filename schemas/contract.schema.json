{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contract-registry.local/schemas/contract.schema.json",
  "title": "Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_id","version","name","namespace","sha256","created_utc"],
  "properties": {
    "contract_id": { "type": "string", "minLength": 3, "maxLength": 128, "pattern": "^[a-z0-9][a-z0-9._-]+$" },
    "version":     { "type": "string", "minLength": 1, "maxLength": 64,  "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$" },
    "name":        { "type": "string", "minLength": 1, "maxLength": 200 },
    "namespace":   { "type": "string", "minLength": 1, "maxLength": 200 },
    "description": { "type": "string", "maxLength": 4000 },
    "sha256":      { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "created_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path","sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1, "maxLength": 500 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    }
  }
}
